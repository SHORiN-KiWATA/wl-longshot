set -euo pipefail

# --- i18n 国际化支持 ---
if echo "${LANG:-}" | grep -iq "zh"; then
    STR_CAP_AREA="截取区域"
    STR_SETTINGS="设置"
    STR_QUIT="退出"
    
    STR_BACK="返回"
    STR_BACKEND="后端"
    STR_ACTION="动作"
    
    STR_ACT_PREV="预览"
    STR_ACT_EDIT="编辑"
    STR_ACT_SAVE="仅保存"
    
    STR_REC_STOP="停止"
    STR_RECORDING="录制中"
    
    STR_GRIM_MODE="Grim 模式"
    STR_CAP_NEXT="截取下一张"
    STR_FINISH="完成"
    STR_ABORT="放弃"
    
    STR_NOTIFY_PROC="处理中"
    STR_NOTIFY_STITCH="正在拼接视频帧..."
    STR_NOTIFY_SUCC="成功"
    STR_NOTIFY_SAVED="已保存至"
    
    STR_GMODE_LBL="截图方式"
    STR_GM_MANUAL="手动框选"
    STR_GM_AUTO="自动等高"
else
    STR_CAP_AREA="Capture Area"
    STR_SETTINGS="Settings"
    STR_QUIT="Quit"
    
    STR_BACK="Back"
    STR_BACKEND="Backend"
    STR_ACTION="Action"
    
    STR_ACT_PREV="Preview"
    STR_ACT_EDIT="Edit"
    STR_ACT_SAVE="Save Only"
    
    STR_REC_STOP="Stop"
    STR_RECORDING="Recording"
    
    STR_GRIM_MODE="Grim Mode"
    STR_CAP_NEXT="Capture Next"
    STR_FINISH="Finish"
    STR_ABORT="Abort"
    
    STR_NOTIFY_PROC="Processing"
    STR_NOTIFY_STITCH="Stitching video frames..."
    STR_NOTIFY_SUCC="Success"
    STR_NOTIFY_SAVED="Saved to"
    
    STR_GMODE_LBL="Capture Mode"
    STR_GM_MANUAL="Manual"
    STR_GM_AUTO="Auto Fixed"
fi

# --- Constants & Paths ---
APP_NAME="wl-longshot"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/wl-longshot"
SAVE_DIR="${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots/longshots"

FILE_BACKEND="$CONFIG_DIR/backend"
FILE_ACTION="$CONFIG_DIR/action"
FILE_GRIM_MODE="$CONFIG_DIR/grim_mode"

if [[ -f "/usr/share/$APP_NAME/stitcher.py" ]]; then
    STITCHER="/usr/share/$APP_NAME/stitcher.py"
else
    STITCHER="$(dirname "${BASH_SOURCE[0]}")/stitcher.py"
fi

mkdir -p "$CONFIG_DIR" "$SAVE_DIR"

# --- 全局安全清理机制 ---
GRIM_TMP_DIR=""
GRIM_FIFO=""
WORKER_PID=""

cleanup() {
    if [[ -n "${GRIM_FIFO:-}" ]]; then 
        echo "DONE" >"$GRIM_FIFO" 2>/dev/null || true
    fi
    if [[ -n "${WORKER_PID:-}" ]]; then 
        kill "$WORKER_PID" 2>/dev/null || true
    fi
    if [[ -n "${GRIM_TMP_DIR:-}" ]] && [[ -d "${GRIM_TMP_DIR:-}" ]]; then 
        rm -rf "$GRIM_TMP_DIR"
    fi
}
trap cleanup EXIT SIGINT SIGTERM

# --- Utils ---
die() { echo "error: $1" >&2; exit 1; }
notify() { command -v notify-send >/dev/null && notify-send -a "$APP_NAME" "$1" "$2"; }
get_conf() { cat "$1" 2>/dev/null || echo "$2"; }
set_conf() { echo "$2" > "$1"; }

get_action_disp() {
    case "$1" in
        "preview") echo "$STR_ACT_PREV" ;;
        "edit") echo "$STR_ACT_EDIT" ;;
        "save") echo "$STR_ACT_SAVE" ;;
        *) echo "$1" ;;
    esac
}

get_gmode_disp() {
    case "$1" in
        "manual") echo "$STR_GM_MANUAL" ;;
        "auto") echo "$STR_GM_AUTO" ;;
        *) echo "$1" ;;
    esac
}

# --- CLI 参数解析 ---
show_help() {
    cat << EOF
Usage: $APP_NAME [OPTIONS]

A smart scrolling screenshot tool for Wayland compositors.

Options:
  -o, --output FILE   Specify the output file path (bypasses main menu)
  -b, --backend NAME  Force use a specific backend (grim, wl-screenrec, wf-recorder)
  -m, --menu CMD      Override the default dmenu-like application (e.g. "fuzzel -d")
  -h, --help          Show this help message and exit
EOF
}

OUT_FILE=""
FORCE_BACKEND=""
CUSTOM_MENU=""

while [[ $# -gt 0 ]]; do
    case $1 in
        -o|--output)
            if [[ $# -lt 2 ]]; then die "Missing argument for $1"; fi
            OUT_FILE="$2"
            shift 2
            ;;
        -b|--backend)
            if [[ $# -lt 2 ]]; then die "Missing argument for $1"; fi
            FORCE_BACKEND="$2"
            shift 2
            ;;
        -m|--menu)
            if [[ $# -lt 2 ]]; then die "Missing argument for $1"; fi
            CUSTOM_MENU="$2"
            shift 2
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            die "Unknown option: $1"
            ;;
    esac
done

if [[ -n "$OUT_FILE" ]]; then
    OUT_FILE="$(realpath -m "$OUT_FILE")"
    mkdir -p "$(dirname "$OUT_FILE")"
fi

# --- 依赖检查 ---
check_deps() {
    local backend="$1"
    local deps=("slurp" "wl-copy" "python3")
    
    if [[ "$backend" == "grim" ]]; then
        deps+=("grim")
    else
        deps+=("$backend")
    fi

    for dep in "${deps[@]}"; do
        command -v "$dep" >/dev/null || die "missing dependency: $dep"
    done
    python3 -c "import cv2, numpy" &>/dev/null || die "missing python modules: opencv-python, numpy"
}

# --- UI 菜单 ---
show_menu() {
    local content="$1"
    local prompt="${2:-$APP_NAME}"
    
    # 1. 如果用户自定义了菜单命令，优先使用 (假设工具支持 -p 传递提示词，符合 dmenu 标准)
    if [[ -n "${CUSTOM_MENU:-}" ]]; then
        echo -e "$content" | eval "$CUSTOM_MENU -p '$prompt: '" || true
    
    # 2. 默认后备工具链：Fuzzel -> Rofi -> Wofi
    elif command -v fuzzel >/dev/null; then
        echo -e "$content" | fuzzel -d --anchor top --y-margin 20 --lines 4 -p "$prompt: " || true
    elif command -v rofi >/dev/null; then
        echo -e "$content" | rofi -dmenu -disable-history -p "$prompt" || true
    elif command -v wofi >/dev/null; then
        echo -e "$content" | wofi -d -i -p "$prompt" --lines 4 --cache-file /dev/null || true
    
    # 3. 纯终端文字交互兜底
    elif [[ -t 0 ]]; then
        echo -e "\n=== $prompt ===" >&2
        mapfile -t options <<< "$(echo -e "$content")"
        local i=1
        for opt in "${options[@]}"; do
            echo "$i) $opt" >&2
            i=$((i + 1))
        done
        
        local ans
        read -r -p "> " ans || true
        if [[ "$ans" =~ ^[0-9]+$ ]] && (( ans > 0 && ans <= ${#options[@]} )); then
            echo "${options[$((ans-1))]}"
        fi
        return 0
    else
        die "No GUI menu found and not running in an interactive terminal."
    fi
}

show_stop_menu() {
    if [[ -n "${CUSTOM_MENU:-}" ]]; then
        echo "$STR_REC_STOP" | eval "$CUSTOM_MENU -p '$STR_RECORDING '" || true
    elif command -v fuzzel >/dev/null; then
        echo "$STR_REC_STOP" | fuzzel -d --anchor top --y-margin 20 --lines 1 --width 12 -p "$STR_RECORDING " || true
    elif command -v rofi >/dev/null; then
        echo "$STR_REC_STOP" | rofi -dmenu -disable-history -p "$STR_RECORDING" -l 1 || true
    elif command -v wofi >/dev/null; then
        echo "$STR_REC_STOP" | wofi -d -i -p "$STR_RECORDING" --lines 1 --width 150 --cache-file /dev/null || true
    elif [[ -t 0 ]]; then
        echo -e "\n=== $STR_RECORDING ===" >&2
        read -r -p "Press [Enter] to $STR_REC_STOP: " _ || true
        echo "$STR_REC_STOP"
    else
        die "No GUI menu found and not running in an interactive terminal."
    fi
}

# --- 后处理 ---
post_process() {
    local out_img="$1"
    [[ ! -f "$out_img" ]] && die "output image not found"
    
    wl-copy < "$out_img"
    notify "$STR_NOTIFY_SUCC" "$STR_NOTIFY_SAVED $(basename "$out_img")"
    
    local action
    action=$(get_conf "$FILE_ACTION" "preview")
    case "$action" in
        "preview") 
            if command -v xdg-open >/dev/null; then
                xdg-open "$out_img" &>/dev/null &
            elif command -v imv >/dev/null; then
                imv "$out_img"
            fi
            ;;
        "edit")    
            command -v satty >/dev/null && satty -f "$out_img" 
            ;;
        "save")    
            ;;
    esac
}

get_output_path() {
    if [[ -n "$OUT_FILE" ]]; then
        echo "$OUT_FILE"
    else
        echo "$SAVE_DIR/longshot_$(date +%Y%m%d_%H%M%S).png"
    fi
}

# --- 录屏后端 ---
run_video() {
    local backend="$1"
    local out_img
    out_img=$(get_output_path)
    
    local geo
    geo=$(slurp) || exit 0
    [[ -z "$geo" ]] && exit 0

    local tmp_vid="/tmp/wl_longshot_$$.mp4"
    local pid

    if [[ "$backend" == "wl-screenrec" ]]; then
        wl-screenrec -g "$geo" -f "$tmp_vid" &>/dev/null &
    else
        wf-recorder -g "$geo" -f "$tmp_vid" -c libx264 -p crf=0 -p preset=ultrafast -p pixel_format=yuv420p &>/dev/null &
    fi
    pid=$!

    sleep 0.5
    kill -0 $pid 2>/dev/null || die "backend crashed: $backend"

    show_stop_menu >/dev/null || true
    
    kill -SIGINT $pid || true
    wait $pid 2>/dev/null || true

    if [[ -f "$tmp_vid" ]]; then
        notify "$STR_NOTIFY_PROC" "$STR_NOTIFY_STITCH"
        python3 "$STITCHER" video --in "$tmp_vid" --out "$out_img"
        rm -f "$tmp_vid"
        post_process "$out_img"
    fi
}

# --- 截图后端 (Grim 异步) ---
run_grim() {
    local out_img
    out_img=$(get_output_path)
    
    local gmode
    gmode=$(get_conf "$FILE_GRIM_MODE" "manual")
    
    GRIM_TMP_DIR="/tmp/wl_longshot_$$"
    GRIM_FIFO="$GRIM_TMP_DIR/fifo"
    local base_img="$GRIM_TMP_DIR/base.png"
    
    mkdir -p "$GRIM_TMP_DIR"

    local geo
    geo=$(slurp) || exit 0
    [[ -z "$geo" ]] && exit 0
    
    IFS=', x' read -r fix_x fix_y fix_w fix_h <<< "$geo"
    grim -g "$geo" "$base_img"

    mkfifo "$GRIM_FIFO"
    exec 3<> "$GRIM_FIFO"

    (
        while read -r task <&3; do
            [[ "$task" == "DONE" ]] && break
            python3 "$STITCHER" incremental --base "$base_img" --next "$task" --out "$base_img"
        done
    ) &
    WORKER_PID=$!

    local idx=0
    while true; do
        local choice
        choice=$(show_menu "$STR_CAP_NEXT\n$STR_FINISH\n$STR_ABORT" "$STR_GRIM_MODE")
        
        if [[ -z "$choice" ]]; then break; fi
        
        case "$choice" in
            *"$STR_CAP_NEXT"*)
                sleep 0.2
                local final_geo
                
                if [[ "$gmode" == "auto" ]]; then
                    final_geo="$geo"
                else
                    local next_geo
                    next_geo=$(slurp) || continue
                    [[ -z "$next_geo" ]] && continue
                    
                    IFS=', x' read -r _tx new_y _tw new_h <<< "$next_geo"
                    final_geo="${fix_x},${new_y} ${fix_w}x${new_h}"
                fi
                
                local next_img="$GRIM_TMP_DIR/next_$idx.png"
                grim -g "$final_geo" "$next_img"
                
                echo "$next_img" >&3 2>/dev/null || true
                idx=$((idx + 1))
                ;;
            *"$STR_FINISH"*) break ;;
            *"$STR_ABORT"*) exit 0 ;;
        esac
    done

    echo "DONE" >&3 2>/dev/null || true
    wait "$WORKER_PID" 2>/dev/null || true
    exec 3>&-

    if [[ -f "$base_img" ]]; then
        mv "$base_img" "$out_img"
        post_process "$out_img"
    fi

    rm -rf "$GRIM_TMP_DIR"
    GRIM_TMP_DIR=""
    GRIM_FIFO=""
    WORKER_PID=""
}

# --- 启动逻辑 ---
backend="${FORCE_BACKEND:-$(get_conf "$FILE_BACKEND" "wl-screenrec")}"
check_deps "$backend"

if [[ -n "$OUT_FILE" ]] || [[ -n "$FORCE_BACKEND" ]]; then
    case "$backend" in
        "wl-screenrec"|"wf-recorder") run_video "$backend" ;;
        "grim") run_grim ;;
        *) die "invalid backend: $backend" ;;
    esac
    exit 0
fi

while true; do
    choice=$(show_menu "$STR_CAP_AREA\n$STR_SETTINGS\n$STR_QUIT" "$APP_NAME")
    
    if [[ -z "$choice" ]]; then exit 0; fi

    case "$choice" in
        *"$STR_CAP_AREA"*)
            case "$backend" in
                "wl-screenrec"|"wf-recorder") run_video "$backend" ;;
                "grim") run_grim ;;
            esac
            break
            ;;
        *"$STR_SETTINGS"*)
            while true; do
                b_lbl=$(get_conf "$FILE_BACKEND" "wl-screenrec")
                a_raw=$(get_conf "$FILE_ACTION" "preview")
                a_lbl=$(get_action_disp "$a_raw")
                
                menu_content="$STR_BACK\n$STR_BACKEND [$b_lbl]\n$STR_ACTION [$a_lbl]"
                
                if [[ "$b_lbl" == "grim" ]]; then
                    g_raw=$(get_conf "$FILE_GRIM_MODE" "manual")
                    g_lbl=$(get_gmode_disp "$g_raw")
                    menu_content="$menu_content\n$STR_GMODE_LBL [$g_lbl]"
                fi
                
                s_choice=$(show_menu "$menu_content" "$STR_SETTINGS")
                [[ -z "$s_choice" ]] && break

                case "$s_choice" in
                    *"$STR_BACK"*) break ;;
                    
                    *"$STR_BACKEND "*)
                        b_choice=$(show_menu "$STR_BACK\nwl-screenrec\nwf-recorder\ngrim" "$STR_BACKEND")
                        case "$b_choice" in
                            *"wl-screenrec"*) set_conf "$FILE_BACKEND" "wl-screenrec" ;;
                            *"wf-recorder"*)  set_conf "$FILE_BACKEND" "wf-recorder" ;;
                            *"grim"*)         set_conf "$FILE_BACKEND" "grim" ;;
                            *"$STR_BACK"*|"") ;;
                        esac
                        backend=$(get_conf "$FILE_BACKEND")
                        check_deps "$backend"
                        ;;
                        
                    *"$STR_ACTION "*)
                        a_choice=$(show_menu "$STR_BACK\n$STR_ACT_PREV\n$STR_ACT_EDIT\n$STR_ACT_SAVE" "$STR_ACTION")
                        case "$a_choice" in
                            *"$STR_ACT_PREV"*) set_conf "$FILE_ACTION" "preview" ;;
                            *"$STR_ACT_EDIT"*) set_conf "$FILE_ACTION" "edit" ;;
                            *"$STR_ACT_SAVE"*) set_conf "$FILE_ACTION" "save" ;;
                            *"$STR_BACK"*|"")  ;;
                        esac
                        ;;
                        
                    *"$STR_GMODE_LBL "*)
                        # 核心修改：点击截图方式直接反转配置，取消子菜单
                        if [[ "$(get_conf "$FILE_GRIM_MODE" "manual")" == "manual" ]]; then
                            set_conf "$FILE_GRIM_MODE" "auto"
                        else
                            set_conf "$FILE_GRIM_MODE" "manual"
                        fi
                        ;;
                esac
            done
            ;;
        *"$STR_QUIT"*) exit 0 ;;
    esac
done