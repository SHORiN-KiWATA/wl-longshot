    STR_OFF="关"
else
    STR_CAP_AREA="Capture Area"
    STR_SETTINGS="Settings"
    STR_QUIT="Quit"
    
    STR_BACK="Back"
    STR_BACKEND="Backend"
    STR_ACTION="Action"
    
    STR_ACT_PREV="Preview"
    STR_ACT_EDIT="Edit"
    STR_ACT_SAVE="Save Only"
    
