    STR_RECORDING="Recording"
    
    STR_GRIM_MODE="Grim Mode"
    STR_CAP_NEXT="Capture Next"
    STR_FINISH="Finish"
    STR_ABORT="Abort"
    
    STR_NOTIFY_PROC="Processing"
    STR_NOTIFY_STITCH="Stitching video frames..."
    STR_NOTIFY_SUCC="Success"
    STR_NOTIFY_SAVED="Saved to"
    
    STR_GMODE_LBL="Capture Mode"
    STR_GM_MANUAL="Manual"
    STR_GM_AUTO="Auto Fixed"
    STR_DEDUP_LBL="Deduplicate"
    STR_FIXED_WIDTH_LBL="Fixed Width"
    STR_ON="On"
    STR_OFF="Off"
fi

# --- Constants & Paths ---
APP_NAME="wl-longshot"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/wl-longshot"
SAVE_DIR="${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots/longshots"
MENU_MIN_LINES=1
SCRIPT_DIR="$(dirname "${BASH_SOURCE[0]}")"

FILE_BACKEND="$CONFIG_DIR/backend"
FILE_ACTION="$CONFIG_DIR/action"
FILE_GRIM_MODE="$CONFIG_DIR/grim_mode"
FILE_GRIM_DEDUP="$CONFIG_DIR/grim_dedup"
FILE_GRIM_FIXED_WIDTH="$CONFIG_DIR/grim_fixed_width"

if [[ -f "$SCRIPT_DIR/stitcher.py" ]]; then
    STITCHER="$SCRIPT_DIR/stitcher.py"
else
    STITCHER="/usr/share/$APP_NAME/stitcher.py"
fi
if [[ -f "$SCRIPT_DIR/drawbox.py" ]]; then
    DRAWBOX="$SCRIPT_DIR/drawbox.py"
else
    DRAWBOX="/usr/share/$APP_NAME/drawbox.py"
fi

mkdir -p "$CONFIG_DIR" "$SAVE_DIR"

# --- 全局安全清理机制 ---
GRIM_TMP_DIR=""
GRIM_FIFO=""
WORKER_PID=""
BOX_PID="" # 【新增】用于记录画框脚本的进程ID
PYTHON_DRAW_SCRIPT="/tmp/wl_longshot_drawbox_$$.py"

cleanup() {
    if [[ -n "${GRIM_FIFO:-}" ]]; then 
        echo "DONE" >"$GRIM_FIFO" 2>/dev/null || true
    fi
    if [[ -n "${WORKER_PID:-}" ]]; then 
        kill "$WORKER_PID" 2>/dev/null || true
    fi
    # 【新增】清理画框进程和临时脚本
    if [[ -n "${BOX_PID:-}" ]]; then 
        kill "$BOX_PID" 2>/dev/null || true
    fi

    if [[ -n "${GRIM_TMP_DIR:-}" ]] && [[ -d "${GRIM_TMP_DIR:-}" ]]; then 
        rm -rf "$GRIM_TMP_DIR"
    fi
}
trap cleanup EXIT SIGINT SIGTERM

# --- 【新增】动态生成画框 Python 脚本 ---
create_draw_box_script() {
    cat << 'EOF' > "$PYTHON_DRAW_SCRIPT"
#!/usr/bin/env python3
import sys, os, gi, cairo
os.environ["GDK_BACKEND"] = "wayland"
gi.require_version("Gtk", "3.0")
gi.require_version("GtkLayerShell", "0.1")
from gi.repository import Gtk, GtkLayerShell, Gdk

if len(sys.argv) != 5:
    sys.exit(1)
global_x, global_y, w, h = map(int, sys.argv[1:5])

window = Gtk.Window()
window.set_app_paintable(True)
window.set_decorated(False)
window.set_resizable(False)

# 动态获取 Matugen / GTK 主题的强调色！
style_context = window.get_style_context()
found, color = style_context.lookup_color("accent_color")
if not found:
    found, color = style_context.lookup_color("theme_selected_bg_color")

if found:
    R, G, B = color.red, color.green, color.blue
else:
    R, G, B = 1.0, 1.0, 1.0

css_provider = Gtk.CssProvider()
css_provider.load_from_data(b"window { background: transparent; margin: 0px; padding: 0px; border: none; } decoration { box-shadow: none; border: none; background: transparent; }")
Gtk.StyleContext.add_provider_for_screen(window.get_screen(), css_provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

drawing_area = Gtk.DrawingArea()
window.add(drawing_area)

if window.get_screen().get_rgba_visual():
    window.set_visual(window.get_screen().get_rgba_visual())

GtkLayerShell.init_for_window(window)
GtkLayerShell.set_layer(window, GtkLayerShell.Layer.OVERLAY)
GtkLayerShell.set_exclusive_zone(window, -1)
GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.TOP, True)
GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.BOTTOM, True)
GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.LEFT, True)
GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.RIGHT, True)

display = Gdk.Display.get_default()
target_monitor = None
local_x, local_y = global_x, global_y

for i in range(display.get_n_monitors()):
    monitor = display.get_monitor(i)
    geom = monitor.get_geometry()
    if geom.x <= global_x < geom.x + geom.width and geom.y <= global_y < geom.y + geom.height:
        target_monitor = monitor
        local_x = global_x - geom.x
        local_y = global_y - geom.y
        break

if target_monitor:
    GtkLayerShell.set_monitor(window, target_monitor)

def on_draw(widget, cr):
    cr.set_antialias(cairo.ANTIALIAS_NONE)
    cr.set_operator(cairo.OPERATOR_SOURCE)
    cr.set_source_rgba(0.0, 0.0, 0.0, 0.0)
    cr.paint()
    cr.set_operator(cairo.OPERATOR_OVER)

    safe_gap = 2
    cx = local_x - safe_gap
    cy = local_y - safe_gap
    cw = w + safe_gap * 2
    ch = h + safe_gap * 2

    # 1. 基础辅助线 (改为 2px)
    cr.set_source_rgba(R, G, B, 0.3)  # 30% 透明度的强调色
    cr.set_line_width(2)              # 变更为 2px
    # 线宽变为 2px 后，Cairo 的路径向外偏移 1.0，保证内侧边缘安全
    cr.rectangle(cx - 1.0, cy - 1.0, cw + 2.0, ch + 2.0)
    cr.stroke()

    # 2. 画高亮的四个相机取景器边角 (保持 3px 不变，视觉上有个层次过渡)
    cr.set_source_rgba(R, G, B, 1.0)
    cr.set_line_width(3)
    
    corner_len = min(20, cw/4, ch/4)
    bx = cx - 1.5
    by = cy - 1.5
    bw = cw + 3
    bh = ch + 3

    # 左上角
    cr.move_to(bx, by + corner_len)
    cr.line_to(bx, by)
    cr.line_to(bx + corner_len, by)
    # 右上角
    cr.move_to(bx + bw - corner_len, by)
    cr.line_to(bx + bw, by)
    cr.line_to(bx + bw, by + corner_len)
    # 右下角
    cr.move_to(bx + bw, by + bh - corner_len)
    cr.line_to(bx + bw, by + bh)
    cr.line_to(bx + bw - corner_len, by + bh)
    # 左下角
    cr.move_to(bx + corner_len, by + bh)
    cr.line_to(bx, by + bh)
    cr.line_to(bx, by + bh - corner_len)
    
    cr.stroke()
    return False

drawing_area.connect("draw", on_draw)
empty_region = cairo.Region()
window.input_shape_combine_region(empty_region)
window.show_all()
Gtk.main()
EOF
    chmod +x "$PYTHON_DRAW_SCRIPT"
}

# --- Utils ---
die() { echo "error: $1" >&2; exit 1; }
notify() { command -v notify-send >/dev/null && notify-send -a "$APP_NAME" "$1" "$2"; }
get_conf() { cat "$1" 2>/dev/null || echo "$2"; }
set_conf() { echo "$2" > "$1"; }

get_action_disp() {
    case "$1" in
        "preview") echo "$STR_ACT_PREV" ;;
        "edit") echo "$STR_ACT_EDIT" ;;
        "save") echo "$STR_ACT_SAVE" ;;
        *) echo "$1" ;;
    esac
}

get_gmode_disp() {
    case "$1" in
        "manual") echo "$STR_GM_MANUAL" ;;
        "auto") echo "$STR_GM_AUTO" ;;
        *) echo "$1" ;;
    esac
}

get_switch_disp() {
    case "$1" in
        "on") echo "$STR_ON" ;;
        "off") echo "$STR_OFF" ;;
        *) echo "$1" ;;
    esac
}

# --- CLI 参数解析 ---
show_help() {
    cat << EOF
Usage: $APP_NAME [OPTIONS]

A smart scrolling screenshot tool for Wayland compositors.

Options:
  -o, --output FILE   Specify the output file path (bypasses main menu)
  -b, --backend NAME  Force use a specific backend (grim, wl-screenrec, wf-recorder)
  -m, --menu CMD      Override the default dmenu-like application (e.g. "fuzzel -d")
  -h, --help          Show this help message and exit
EOF
}

OUT_FILE=""
FORCE_BACKEND=""
CUSTOM_MENU=""

while [[ $# -gt 0 ]]; do
    case $1 in
        -o|--output)
            if [[ $# -lt 2 ]]; then die "Missing argument for $1"; fi
            OUT_FILE="$2"
            shift 2
            ;;
        -b|--backend)
            if [[ $# -lt 2 ]]; then die "Missing argument for $1"; fi
            FORCE_BACKEND="$2"
            shift 2
            ;;
        -m|--menu)
            if [[ $# -lt 2 ]]; then die "Missing argument for $1"; fi
            CUSTOM_MENU="$2"
            shift 2
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            die "Unknown option: $1"
            ;;
    esac
done

if [[ -n "$OUT_FILE" ]]; then
    OUT_FILE="$(realpath -m "$OUT_FILE")"
    mkdir -p "$(dirname "$OUT_FILE")"
fi

# --- 依赖检查 ---
check_deps() {
    local backend="$1"
    local deps=("slurp" "wl-copy" "python3")
    
    if [[ "$backend" == "grim" ]]; then
        deps+=("grim")
    else
        deps+=("$backend")
    fi

    for dep in "${deps[@]}"; do
        command -v "$dep" >/dev/null || die "missing dependency: $dep"
    done
    python3 -c "import cv2, numpy" &>/dev/null || die "missing python modules: opencv-python, numpy"
    # 隐藏检查 GTK 和 LayerShell 依赖
    python3 -c "import gi; gi.require_version('Gtk', '3.0'); gi.require_version('GtkLayerShell', '0.1')" &>/dev/null || die "missing python modules for drawing box: python-gobject, gtk-layer-shell"
}

# --- UI 菜单 ---
show_menu() {
    local content="$1"
    local prompt="${2:-$APP_NAME}"
    local lines=1
    local rest="$content"

    while [[ "$rest" == *\\n* ]]; do
        lines=$((lines + 1))
        rest="${rest#*\\n}"
    done

    if (( lines < MENU_MIN_LINES )); then
        lines=$MENU_MIN_LINES
    fi
    
    if [[ -n "${CUSTOM_MENU:-}" ]]; then
        echo -e "$content" | eval "$CUSTOM_MENU -p '$prompt: '" || true
    elif command -v fuzzel >/dev/null; then
        echo -e "$content" | fuzzel -d --anchor top --y-margin 20 --lines "$lines" -p "$prompt: " || true
    elif command -v rofi >/dev/null; then
        echo -e "$content" | rofi -dmenu -disable-history -p "$prompt" || true
    elif command -v wofi >/dev/null; then
        echo -e "$content" | wofi -d -i -p "$prompt" --lines "$lines" --cache-file /dev/null || true
    elif [[ -t 0 ]]; then
        echo -e "\n=== $prompt ===" >&2
        mapfile -t options <<< "$(echo -e "$content")"
        local i=1
        for opt in "${options[@]}"; do
            echo "$i) $opt" >&2
            i=$((i + 1))
        done
        local ans
        read -r -p "> " ans || true
        if [[ "$ans" =~ ^[0-9]+$ ]] && (( ans > 0 && ans <= ${#options[@]} )); then
            echo "${options[$((ans-1))]}"
        fi
        return 0
    else
        die "No GUI menu found and not running in an interactive terminal."
    fi
}

show_stop_menu() {
    if [[ -n "${CUSTOM_MENU:-}" ]]; then
        echo "$STR_REC_STOP" | eval "$CUSTOM_MENU -p '$STR_RECORDING '" || true
    elif command -v fuzzel >/dev/null; then
        echo "$STR_REC_STOP" | fuzzel -d --anchor top --y-margin 20 --lines 1 --width 12 -p "$STR_RECORDING " || true
    elif command -v rofi >/dev/null; then
        echo "$STR_REC_STOP" | rofi -dmenu -disable-history -p "$STR_RECORDING" -l 1 || true
    elif command -v wofi >/dev/null; then
        echo "$STR_REC_STOP" | wofi -d -i -p "$STR_RECORDING" --lines 1 --width 150 --cache-file /dev/null || true
    elif [[ -t 0 ]]; then
        echo -e "\n=== $STR_RECORDING ===" >&2
        read -r -p "Press [Enter] to $STR_REC_STOP: " _ || true
        echo "$STR_REC_STOP"
    else
        die "No GUI menu found and not running in an interactive terminal."
    fi
}

# --- 后处理 ---
post_process() {
    local out_img="$1"
    [[ ! -f "$out_img" ]] && die "output image not found"
    
    wl-copy < "$out_img"
    notify "$STR_NOTIFY_SUCC" "$STR_NOTIFY_SAVED $(basename "$out_img")"
    
    local action
    action=$(get_conf "$FILE_ACTION" "preview")
    case "$action" in
        "preview") 
            if command -v xdg-open >/dev/null; then
                xdg-open "$out_img" &>/dev/null &
            elif command -v imv >/dev/null; then
                imv "$out_img"
            fi
            ;;
        "edit")    
            command -v satty >/dev/null && satty -f "$out_img" 
            ;;
        "save")    
            ;;
    esac
}

get_output_path() {
    if [[ -n "$OUT_FILE" ]]; then
        echo "$OUT_FILE"
    else
        echo "$SAVE_DIR/longshot_$(date +%Y%m%d_%H%M%S).png"
    fi
}

# --- 录屏后端 ---
run_video() {
    local backend="$1"
    local out_img
    out_img=$(get_output_path)
    
    local geo
    geo=$(slurp) || exit 0
    [[ -z "$geo" ]] && exit 0

    # 【新增】录屏后端：在获取坐标后立即显示红框
    create_draw_box_script
    IFS=', x' read -r fix_x fix_y fix_w fix_h <<< "$geo"
    python3 "$DRAWBOX" "$fix_x" "$fix_y" "$fix_w" "$fix_h" &
    BOX_PID=$!

    sleep 0.3

    local tmp_vid="/tmp/wl_longshot_$$.mp4"
    local pid

    if [[ "$backend" == "wl-screenrec" ]]; then
        wl-screenrec -g "$geo" -f "$tmp_vid" &>/dev/null &
    else
        wf-recorder -g "$geo" -f "$tmp_vid" -c libx264 -p crf=0 -p preset=ultrafast -p pixel_format=yuv420p &>/dev/null &
    fi
    pid=$!

    sleep 0.5
    kill -0 $pid 2>/dev/null || die "backend crashed: $backend"

    show_stop_menu >/dev/null || true
    
    kill -SIGINT $pid || true
    wait $pid 2>/dev/null || true

    # 【新增】录制完成，杀掉画框进程
    if [[ -n "${BOX_PID:-}" ]]; then 
        kill "$BOX_PID" 2>/dev/null || true
        BOX_PID=""
    fi

    if [[ -f "$tmp_vid" ]]; then
        notify "$STR_NOTIFY_PROC" "$STR_NOTIFY_STITCH"
        python3 "$STITCHER" video --in "$tmp_vid" --out "$out_img"
        rm -f "$tmp_vid"
        post_process "$out_img"
    fi
}

# --- 截图后端 (Grim 异步) ---
run_grim() {
    local out_img
    out_img=$(get_output_path)
    
    local gmode
    gmode=$(get_conf "$FILE_GRIM_MODE" "auto") # 【已修改为默认 auto】
    local grim_dedup
    grim_dedup=$(get_conf "$FILE_GRIM_DEDUP" "on")
    local grim_fixed_width
    grim_fixed_width=$(get_conf "$FILE_GRIM_FIXED_WIDTH" "on")
    
    GRIM_TMP_DIR="/tmp/wl_longshot_$$"
    GRIM_FIFO="$GRIM_TMP_DIR/fifo"
    local base_img="$GRIM_TMP_DIR/base.png"
    
    mkdir -p "$GRIM_TMP_DIR"

    local geo
    geo=$(slurp) || exit 0
    [[ -z "$geo" ]] && exit 0
    
    IFS=', x' read -r fix_x fix_y fix_w fix_h <<< "$geo"
    
    # 【新增】Grim 自动等高模式下：获取坐标后显示红框
    if [[ "$gmode" == "auto" ]]; then
        create_draw_box_script
        python3 "$DRAWBOX" "$fix_x" "$fix_y" "$fix_w" "$fix_h" &
        BOX_PID=$!
    fi

    grim -g "$geo" "$base_img"

    mkfifo "$GRIM_FIFO"
    exec 3<> "$GRIM_FIFO"

    (
        while read -r task <&3; do
            [[ "$task" == "DONE" ]] && break
            local stitch_args=(incremental --base "$base_img" --next "$task" --out "$base_img")
            if [[ "$gmode" == "manual" && "$grim_fixed_width" == "off" ]]; then
                stitch_args+=(--keep-widths)
            fi
            if [[ "$gmode" == "manual" && "$grim_dedup" == "off" ]]; then
                stitch_args+=(--no-dedup)
            fi
            python3 "$STITCHER" "${stitch_args[@]}"
        done
    ) &
    WORKER_PID=$!

    local idx=0
    while true; do
        local choice
        choice=$(show_menu "$STR_CAP_NEXT\n$STR_FINISH\n$STR_ABORT" "$STR_GRIM_MODE")
        
        if [[ -z "$choice" ]]; then break; fi
        
        case "$choice" in
            *"$STR_CAP_NEXT"*)
                sleep 0.2
                local final_geo
                
                if [[ "$gmode" == "auto" ]]; then
                    final_geo="$geo"
                else
                    local next_geo
                    next_geo=$(slurp) || continue
                    [[ -z "$next_geo" ]] && continue

                    if [[ "$grim_fixed_width" == "off" ]]; then
                        final_geo="$next_geo"
                    else
                        IFS=', x' read -r _tx new_y _tw new_h <<< "$next_geo"
                        final_geo="${fix_x},${new_y} ${fix_w}x${new_h}"
                    fi
                fi
                
                local next_img="$GRIM_TMP_DIR/next_$idx.png"
                grim -g "$final_geo" "$next_img"
                
                echo "$next_img" >&3 2>/dev/null || true
                idx=$((idx + 1))
                ;;
            *"$STR_FINISH"*) break ;;
            *"$STR_ABORT"*) exit 0 ;;
        esac
    done

    echo "DONE" >&3 2>/dev/null || true
    wait "$WORKER_PID" 2>/dev/null || true
    exec 3>&-

    # 【新增】流程结束（无论是Finish还是Abort退出循环），杀掉画框进程
    if [[ -n "${BOX_PID:-}" ]]; then 
        kill "$BOX_PID" 2>/dev/null || true
        BOX_PID=""
    fi

    if [[ -f "$base_img" ]]; then
        mv "$base_img" "$out_img"
        post_process "$out_img"
    fi

    rm -rf "$GRIM_TMP_DIR"
    GRIM_TMP_DIR=""
    GRIM_FIFO=""
    WORKER_PID=""
}

# --- 启动逻辑 ---
backend="${FORCE_BACKEND:-$(get_conf "$FILE_BACKEND" "grim")}" # 【已修改为默认 grim】
check_deps "$backend"

if [[ -n "$OUT_FILE" ]] || [[ -n "$FORCE_BACKEND" ]]; then
    case "$backend" in
        "wl-screenrec"|"wf-recorder") run_video "$backend" ;;
        "grim") run_grim ;;
        *) die "invalid backend: $backend" ;;
    esac
    exit 0
fi

while true; do
    choice=$(show_menu "$STR_CAP_AREA\n$STR_SETTINGS\n$STR_QUIT" "$APP_NAME")
    
    if [[ -z "$choice" ]]; then exit 0; fi

    case "$choice" in
        *"$STR_CAP_AREA"*)
            case "$backend" in
                "wl-screenrec"|"wf-recorder") run_video "$backend" ;;
                "grim") run_grim ;;
            esac
            break
            ;;
        *"$STR_SETTINGS"*)
            while true; do
                b_lbl=$(get_conf "$FILE_BACKEND" "grim") # 【已修改为默认 grim】
                a_raw=$(get_conf "$FILE_ACTION" "preview")
                a_lbl=$(get_action_disp "$a_raw")
                
                menu_content="$STR_BACK\n$STR_BACKEND [$b_lbl]\n$STR_ACTION [$a_lbl]"
                
                if [[ "$b_lbl" == "grim" ]]; then
                    g_raw=$(get_conf "$FILE_GRIM_MODE" "auto") # 【已修改为默认 auto】
                    g_lbl=$(get_gmode_disp "$g_raw")
                    menu_content="$menu_content\n$STR_GMODE_LBL [$g_lbl]"

                    if [[ "$g_raw" == "manual" ]]; then
                        w_raw=$(get_conf "$FILE_GRIM_FIXED_WIDTH" "on")
                        w_lbl=$(get_switch_disp "$w_raw")
                        d_raw=$(get_conf "$FILE_GRIM_DEDUP" "on")
                        d_lbl=$(get_switch_disp "$d_raw")
                        menu_content="$menu_content\n$STR_FIXED_WIDTH_LBL [$w_lbl]"
                        menu_content="$menu_content\n$STR_DEDUP_LBL [$d_lbl]"
                    fi
                fi
                
                s_choice=$(show_menu "$menu_content" "$STR_SETTINGS")
                [[ -z "$s_choice" ]] && break

                case "$s_choice" in
                    *"$STR_BACK"*) break ;;
                    
                    *"$STR_BACKEND "*)
                        b_choice=$(show_menu "$STR_BACK\nwl-screenrec\nwf-recorder\ngrim" "$STR_BACKEND")
                        case "$b_choice" in
                            *"wl-screenrec"*) set_conf "$FILE_BACKEND" "wl-screenrec" ;;
                            *"wf-recorder"*)  set_conf "$FILE_BACKEND" "wf-recorder" ;;
                            *"grim"*)         set_conf "$FILE_BACKEND" "grim" ;;
                            *"$STR_BACK"*|"") ;;
                        esac
                        backend=$(get_conf "$FILE_BACKEND")
                        check_deps "$backend"
                        ;;
                        
                    *"$STR_ACTION "*)
                        a_choice=$(show_menu "$STR_BACK\n$STR_ACT_PREV\n$STR_ACT_EDIT\n$STR_ACT_SAVE" "$STR_ACTION")
                        case "$a_choice" in
                            *"$STR_ACT_PREV"*) set_conf "$FILE_ACTION" "preview" ;;
                            *"$STR_ACT_EDIT"*) set_conf "$FILE_ACTION" "edit" ;;
                            *"$STR_ACT_SAVE"*) set_conf "$FILE_ACTION" "save" ;;
                            *"$STR_BACK"*|"")  ;;
                        esac
                        ;;
                        
                    *"$STR_GMODE_LBL "*)
                        # 核心修改：点击截图方式直接反转配置，取消子菜单
                        if [[ "$(get_conf "$FILE_GRIM_MODE" "auto")" == "manual" ]]; then # 【此处对应修改回退值为 auto】
                            set_conf "$FILE_GRIM_MODE" "auto"
                        else
                            set_conf "$FILE_GRIM_MODE" "manual"
                        fi
                        ;;

                    *"$STR_FIXED_WIDTH_LBL "*)
                        if [[ "$(get_conf "$FILE_GRIM_FIXED_WIDTH" "on")" == "on" ]]; then
                            set_conf "$FILE_GRIM_FIXED_WIDTH" "off"
                        else
                            set_conf "$FILE_GRIM_FIXED_WIDTH" "on"
                        fi
                        ;;

                    *"$STR_DEDUP_LBL "*)
                        if [[ "$(get_conf "$FILE_GRIM_DEDUP" "on")" == "on" ]]; then
                            set_conf "$FILE_GRIM_DEDUP" "off"
                        else
                            set_conf "$FILE_GRIM_DEDUP" "on"
                        fi
                        ;;
                esac
            done
            ;;
        *"$STR_QUIT"*) exit 0 ;;
    esac
done
