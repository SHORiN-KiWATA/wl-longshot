    STR_NOTIFY_STITCH="正在拼接视频帧..."
    STR_NOTIFY_SUCC="成功"
    STR_NOTIFY_SAVED="已保存至"
    
    STR_GMODE_LBL="截图方式"
    STR_GM_MANUAL="手动框选"
    STR_GM_AUTO="自动等高"
    STR_DEDUP_LBL="去重"
    STR_FIXED_WIDTH_LBL="定宽"
