    STR_SETTINGS="设置"
    STR_QUIT="退出"
    
    STR_BACK="返回"
    STR_BACKEND="后端"
    STR_ACTION="动作"
    
    STR_ACT_PREV="预览"
    STR_ACT_EDIT="编辑"
    STR_ACT_SAVE="仅保存"
    
    STR_REC_STOP="停止"
    STR_RECORDING="录制中"
    
    STR_GRIM_MODE="Grim 模式"
    STR_CAP_NEXT="截取下一张"
    STR_FINISH="完成"
    STR_ABORT="放弃"
    
